POSTGRES_DB=flight_prices
POSTGRES_USER=tracker
POSTGRES_PASSWORD=tracker_password
DASHBOARD_DB_USER=dashboard_reader
DASHBOARD_DB_PASSWORD=dashboard_password
DASHBOARD_PORT=8502

SCRAPE_INTERVAL_SECONDS=60
MAX_CONCURRENCY=12
REQUEST_TIMEOUT_SECONDS=20
RETRY_ATTEMPTS=3
RETRY_BACKOFF_SECONDS=2
RAW_DATA_DIR=/app/raw_data

FUEL_REQUEST_TIMEOUT_SECONDS=20
FUEL_DATA_DIR=/app/fuel_data
FUEL_CONFIG_FILE=/app/config/pricing.json
STOOQ_BRENT_SYMBOL=cb.f
FUEL_SCHEDULE_MODE=interval
FUEL_DAILY_HOUR=8
FUEL_HOURLY_INTERVAL=1
FUEL_INTERVAL_MINUTES=5
FUEL_RETRY_DELAY_MINUTES=15
FUEL_BRENT_FALLBACK_USD=85.00
FUEL_TIMEZONE=Asia/Ho_Chi_Minh
FUEL_RUN_ON_STARTUP=true
VCB_EXCHANGE_URL=https://portal.vietcombank.com.vn/Usercontrols/TVPortal.TyGia/pXML.aspx?b=10
VCB_CURRENCY_CODE=USD

# Reverse engineered endpoint captured from DevTools -> Network -> Fetch/XHR
VNA_API_URL=https://example.com/api/availability
VNA_API_METHOD=GET
VNA_VERIFY_SSL=true
VNA_PARSER_MODE=skyscanner_itineraries

# Static headers. Authorization and session headers are added separately when set.
VNA_HEADERS_TEMPLATE={"accept":"application/json","accept-language":"vi,en;q=0.9,en-GB;q=0.8,en-US;q=0.7","content-type":"application/json","user-agent":"Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/147.0.0.0 Safari/537.36 Edg/147.0.0.0"}

# Query string template for GET endpoints. Leave {} when not used.
VNA_QUERY_TEMPLATE={}

# JSON body template. Available placeholders: {origin}, {destination}, {travel_date}, {trip_duration}, {range_of_departure}, {location}, {bearer_token}, {session_id}
VNA_PAYLOAD_TEMPLATE={}

# Optional tokens copied from the browser session while reverse engineering the API
VNA_BEARER_TOKEN=
VNA_SESSION_HEADER_NAME=X-Session-Id
VNA_SESSION_ID=
VNA_COOKIE=
